# CloudBudget - required runtime settings
JWT_SECRET=
DATABASE_URL=postgresql+psycopg://cloudbudget:cloudbudget@postgres:5432/cloudbudget
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
DUCKDB_PATH=/data/cloudbudget.duckdb

# Optional API integration settings
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=cloudbudget@example.com

# Optional Celery overrides
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0
