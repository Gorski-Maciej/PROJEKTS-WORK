# CloudBudget 2.0 example environment
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Security
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Multi-tenant defaults
DEFAULT_TENANT_ID=demo-tenant

# Databases
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cloudbudget
POSTGRES_USER=cloudbudget
POSTGRES_PASSWORD=cloudbudget
DATABASE_URL=postgresql+psycopg://cloudbudget:cloudbudget@postgres:5432/cloudbudget

# DuckDB / analytics
DUCKDB_PATH=/data/cloudbudget.duckdb

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Keycloak / OIDC
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=cloudbudget
KEYCLOAK_CLIENT_ID=cloudbudget-api
KEYCLOAK_CLIENT_SECRET=change-me

# Cloud providers (optional in local development)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=

# Notification channels
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
