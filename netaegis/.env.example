# NetAegis - platform settings
REDIS_URL=redis://redis:6379/0
MAIN_MCP_URL=http://main_mcp:8000
OPERATIONAL_MCP_URL=http://operational_mcp:8001
NETAEGIS_MODE=standalone

# Demo auth (change for non-demo usage)
NETAEGIS_DEMO_USERNAME=admin
NETAEGIS_DEMO_PASSWORD=admin

# NetPulse agent optional overrides
NETPULSE_AGENT_ID=netpulse-01
NETPULSE_INTERVAL=30
NETPULSE_GATEWAY_IP=192.168.1.1
NETPULSE_APP_HOST=192.168.1.10
NETPULSE_APP_PORT=80

# SecLog agent optional overrides
SECLOG_AGENT_ID=seclog-01
SECLOG_WATCH_PATHS=/var/log/auth.log,/var/log/nginx/access.log

# NetConfig agent required credentials
NETCONFIG_AGENT_ID=netconfig-01
NETCONFIG_LOCAL_REPO=/app/.agent-configs
NETCONFIG_DEVICE_IP=192.168.1.1
NETCONFIG_DEVICE_USERNAME=
NETCONFIG_DEVICE_PASSWORD=
