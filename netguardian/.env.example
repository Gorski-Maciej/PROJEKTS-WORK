# NetGuardian - required runtime settings
ABUSEIPDB_API_KEY=
SLACK_WEBHOOK_URL=
MISP_URL=
MISP_KEY=
JWT_SECRET=

# Kafka / Redis / DB (normally provided by docker-compose defaults)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
REDIS_HOST=redis
DATABASE_URL=postgresql://postgres:netguardian@timescaledb:5432/netguardian
DUCKDB_PATH=/data/netguardian.db

# GeoIP and threat intel
SKIP_GEOIP_CHECK=true
GEOIP_DB=/app/data/GeoLite2-City.mmdb
MAXMIND_LICENSE_KEY=

# Response executor (SSH)
SSH_PRIVATE_KEY_FILE=/app/ssh/id_rsa
SSH_AGENT_HOST=agent
SSH_AGENT_USER=root
NETGUARDIAN_ADMIN_PASSWORD=
NETGUARDIAN_VIEWER_PASSWORD=
