# InfraFlow - required runtime settings
JWT_SECRET=
REDIS_HOST=redis
REDIS_PORT=6379
DATABASE_URL=postgresql://postgres:infraflow@timescaledb:5432/infraflow
CONFIG_PATH=/app/config/servers.yml
PROMETHEUS_SCRAPE_INTERVAL=15s

# Optional SSH tuning
SSH_CONNECT_TIMEOUT=10

# Optional notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=infraflow@example.com
SLACK_WEBHOOK=
EMAIL_TO=
INFRAFLOW_ADMIN_PASSWORD=
INFRAFLOW_VIEWER_PASSWORD=
