# CloudBudget runtime settings
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars

# Database
POSTGRES_DB=cloudbudget
POSTGRES_USER=cloudbudget
POSTGRES_PASSWORD=cloudbudget
DATABASE_URL=postgresql+psycopg://cloudbudget:cloudbudget@postgres:5432/cloudbudget

# Cache / broker
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Optional integrations
SLACK_WEBHOOK_URL=
