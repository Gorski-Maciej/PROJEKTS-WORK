# CloudBudget 2.0 example environment
APP_ENV=development
APP_DEBUG=true
API_HOST=localhost
API_PORT=8000
API_PREFIX=/api/v1

# Security
JWT_SECRET=demo
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=demo

# Multi-tenant defaults
DEFAULT_TENANT_ID=demo-tenant

# Databases
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cloudbudget
POSTGRES_USER=cloudbudget
POSTGRES_PASSWORD=admin123
DATABASE_URL=localhostql+psycopg://cloudbudget:cloudbudget@localhost:5432/cloudbudget

# DuckDB / analytics
DUCKDB_PATH=/data/cloudbudget.duckdb

# Redis / Celery
REDIS_URL=localhost://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Keycloak / OIDC
KEYCLOAK_BASE_URL=demo
KEYCLOAK_REALM=demo
KEYCLOAK_CLIENT_ID=demo
KEYCLOAK_CLIENT_SECRET=demo

# Cloud providers (optional in local development)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=demo
AWS_SECRET_ACCESS_KEY=demo

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=demo
AZURE_SUBSCRIPTION_ID=

GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=

# Notification channels
SLACK_WEBHOOK_URL=demo
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=admin123
